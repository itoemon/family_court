# E2E テスト用環境変数のテンプレート
# このファイルをコピーして `.env.test` として使う（`.env.test` は gitignored）
#
# 使い分け:
#   .env.local → 通常開発（`npm run dev`）/ 本番 Supabase 接続
#   .env.test  → E2E 実行（`npm run dev:test` / Playwright）/ テスト用 Supabase 接続
#
# セットアップ手順は docs/operations/e2e-test-db.md を参照。

# ── テストモード ────────────────────────────────────────────────────────────
# TEST_MODE=1 のとき lib/judge.ts:generateJudgeMessage が実 Anthropic 呼び出しを
# 行わず決定的なモック応答を返す。これにより E2E が「原告の API キー SET 経路」
# (judge_messages への closing INSERT など) を実キー・課金なしで検証できる
# (BUG-005-4 / LOW-001-BUG005)。`npm run dev:test` を直接使う場合に必要。
# scripts/agents.sh のパイプライン経由では同値が export されるため自動で有効。
TEST_MODE=1

# ── テスト用 Supabase プロジェクト ──────────────────────────────────────────
# Supabase ダッシュボードで本番とは別のプロジェクトを作成して埋める
NEXT_PUBLIC_SUPABASE_URL=https://<test-project-ref>.supabase.co
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<test_value>

# Settings → API → Secret key
SUPABASE_SECRET_KEY=sb_secret_<test_value>
SUPABASE_ACCESS_TOKEN=sbp_<test_value>
SUPABASE_PROJECT_REF=<test-project-ref>

# API キー暗号化用シークレット（32バイト hex）
# 本番と別の値を使うこと（既存ユーザーの暗号化済みデータと干渉させない）
# 生成: `openssl rand -hex 32`
ENCRYPTION_KEY=<32-byte-hex>

# ゲストトークンのシークレット（32バイト hex）
# 同様に本番と別の値
GUEST_TOKEN_SECRET=<32-byte-hex>

# E2E テスト用ユーザー（テスト Supabase の Auth に事前登録が必要）
# 本番の E2E_TEST_EMAIL_A/B と同じメールでも構わない（プロジェクトが別なので衝突しない）
E2E_TEST_EMAIL_A=e2e_user_a@example.com
E2E_TEST_EMAIL_B=e2e_user_b@example.com
E2E_TEST_PASSWORD_A=E2eTest123!
E2E_TEST_PASSWORD_B=E2eTest123!

# Redis（Upstash）
# テスト用に別インスタンスを作るのが理想だが、本番と共有でも実害は小さい
# （ratelimit はキーごとに独立、テストキーは破棄可能）
UPSTASH_REDIS_REST_URL=https://<test-instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<test_token>
